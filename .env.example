# Option A — Gemini API (AI Studio key)
GEMINI_API_KEY=

# Option B — Vertex AI (uses Application Default Credentials:
#   gcloud auth application-default login)
GOOGLE_GENAI_USE_VERTEXAI=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=

# Optional model override (default: gemini-2.5-flash-lite)
GEMINI_MODEL=
